# Allow release-it's commit on main (chore(release): v...). Set by scripts/release.js.
if [ "$RELEASE_IT" = "1" ]; then
  pnpm lint-staged
  exit 0
fi

branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo ""
  echo "  ✗ refuse: commit on $branch is not allowed."
  echo "  → run: git checkout -b <type>/<scope>"
  echo ""
  exit 1
fi

pnpm lint-staged
