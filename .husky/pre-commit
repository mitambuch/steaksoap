# Release-it escape hatch (env var + staged-file pattern check).
# scripts/release.js sets RELEASE_IT=1; release-it only stages package.json
# + CHANGELOG.md for the `chore(release): v...` commit. Anything else staged
# under RELEASE_IT=1 is not a real release — fail loudly.
if [ "$RELEASE_IT" = "1" ]; then
  staged=$(git diff --cached --name-only | sort | tr '\n' ',' | sed 's/,$//')
  if [ "$staged" != "CHANGELOG.md,package.json" ]; then
    echo ""
    echo "  ✗ RELEASE_IT=1 set but staged files are not the release pattern."
    echo "  → expected: CHANGELOG.md,package.json"
    echo "  → got:      $staged"
    echo ""
    exit 1
  fi
  pnpm lint-staged
  exit 0
fi

branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo ""
  echo "  ✗ refuse: commit on $branch is not allowed."
  echo "  → run: git checkout -b <type>/<scope>"
  echo ""
  exit 1
fi

pnpm lint-staged
