{
  "name": "project-base",
  "version": "5.4.1",
  "type": "module",
  "description": "Private production base — React 19 + TypeScript 5.9 + Vite 7 + Tailwind CSS 4",
  "author": "Mirco",
  "license": "UNLICENSED",
  "private": true,
  "_baseProject": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/sync-csp-hash.js",
    "build": "vite build",
    "postbuild": "node scripts/prerender-meta.js",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate": "pnpm lint && pnpm typecheck && pnpm docs:sync:check && pnpm memory:index:check && pnpm test:coverage && pnpm build",
    "validate:full": "pnpm validate && pnpm test:e2e",
    "docs:sync": "node scripts/sync-reference-counts.js",
    "docs:sync:check": "node scripts/sync-reference-counts.js --check",
    "preinstall": "node scripts/ensure-pnpm.js",
    "postinstall": "node scripts/setup-bootstrap.js --check",
    "prepare": "husky",
    "setup": "node scripts/setup-bootstrap.js",
    "base:update": "node scripts/setup.js --update",
    "base:patch": "node scripts/base-patch.js",
    "memory:index": "node scripts/memory-index.js",
    "memory:index:check": "node scripts/memory-index.js --check",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "analyze": "ANALYZE=true vite build",
    "audit:ci": "pnpm audit --prod --audit-level=high",
    "doctor": "node scripts/doctor.js",
    "done": "node scripts/done.js"
  },
  "dependencies": {
    "@sanity/client": "^7.21.0",
    "@sanity/image-url": "^2.1.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@clack/prompts": "^1.2.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "release-it": "^19.2.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "minimatch": ">=10.2.1",
      "rollup": ">=4.58.0",
      "basic-ftp": ">=5.2.2",
      "defu": ">=6.1.5",
      "undici": ">=6.24.0",
      "tmp": ">=0.2.4"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.28.0"
}
