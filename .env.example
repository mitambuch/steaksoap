# ─── Copy this file to .env.local and fill in the values ───
# NEVER commit .env.local
# All variables have safe fallbacks — the app works without .env.local

# Cloudinary (optional) — image optimization via Cloudinary
# Get your cloud name at https://cloudinary.com/console
# If empty, images use raw URLs without optimization
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# App identity (required for SEO/OG tags)
# Used in <title>, meta tags, and Open Graph
VITE_APP_NAME=Project Name

# App URL (required for production)
# Used for canonical URLs, OG tags, and sitemap generation
# Falls back to http://localhost:5173 if not set
VITE_APP_URL=http://localhost:5173

# ─── i18n ────────────────────────────────────────────────
# Default locale at first visit (fallback when browser language is unsupported).
# Supported: fr | de | en
VITE_DEFAULT_LOCALE=fr

# ─── Sanity CMS (optional) ───────────────────────────────
# The app works without Sanity — it falls back to local fixtures when these
# are empty (see hasSanity guard in src/lib/sanity.ts).
# Get values at https://sanity.io/manage after creating a project.
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-06-01

# Sanity write token — used by Claude's /wire-content command and Studio
# seed scripts to push content programmatically.
# NEVER prefix with VITE_ (would bundle into client code — see security.md).
# Create at sanity.io/manage → [project] → API → Tokens → Editor scope.
# Keep in .env.local only.
SANITY_WRITE_TOKEN=
